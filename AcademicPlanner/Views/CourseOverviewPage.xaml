<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AcademicPlanner.Views.CourseOverviewPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EFEFEF">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0"
              Padding="16,12,16,8"
              ColumnDefinitions="56,*,56"
              ColumnSpacing="16"
              BackgroundColor="White">

            <ImageButton Grid.Column="0"
                         Source="icon_back.png"
                         BackgroundColor="Transparent"
                         WidthRequest="48"
                         HeightRequest="48"
                         Padding="0"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Aspect="AspectFit"
                         Clicked="OnBackClicked" />

            <Image Grid.Column="1"
                   Source="wgu_owl.png"
                   HeightRequest="56"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Aspect="AspectFit" />

            <ImageButton Grid.Column="2"
                         Source="icon_edit.png"
                         BackgroundColor="Transparent"
                         WidthRequest="48"
                         HeightRequest="48"
                         Padding="0"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Aspect="AspectFit"
                         Clicked="OnEditCourseClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="#002f51"
                StrokeThickness="0"
                Padding="0,10">
            <Label Text="Course Overview"
                   TextColor="White"
                   FontSize="22"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="22,22,22,30"
                                 Spacing="18">

                <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="6"
                  HorizontalOptions="Fill"
                  VerticalOptions="Center">         

                    <Label Grid.Column="0"
                       x:Name="CourseTitleLabel"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="Black"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"
                       HorizontalOptions="Fill"
                       VerticalTextAlignment="Center" />

                    <Image Grid.Column="1"
                       x:Name="CourseBellImage"
                       Source="icon_bell_inactive.png"
                       WidthRequest="30"
                       HeightRequest="30"
                       VerticalOptions="Start"
                       Margin="0,4,0,0"
                       Aspect="AspectFit" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      Padding="6,0">

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Status:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           x:Name="CourseStatusLabel"
                           FontSize="18"
                           TextColor="Black" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="Start Date:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="1"
                           Grid.Column="1"
                           x:Name="CourseStartDateLabel"
                           FontSize="18"
                           TextColor="Black" />

                    <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="End Date:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="2"
                           Grid.Column="1"
                           x:Name="CourseEndDateLabel"
                           FontSize="18"
                           TextColor="Black" />

                    <Label Grid.Row="3"
                           Grid.Column="0"
                           Text="Instructor:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="3"
                           Grid.Column="1"
                           x:Name="InstructorNameLabel"
                           FontSize="18"
                           TextColor="Black" />

                    <Label Grid.Row="4"
                           Grid.Column="0"
                           Text="Phone:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="4"
                           Grid.Column="1"
                           x:Name="InstructorPhoneLabel"
                           FontSize="18"
                           TextColor="Black" />

                    <Label Grid.Row="5"
                           Grid.Column="0"
                           Text="Email:"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Grid.Row="5"
                           Grid.Column="1"
                           x:Name="InstructorEmailLabel"
                           FontSize="18"
                           TextColor="Black" />
                </Grid>

                <Border Stroke="Black"
                        StrokeThickness="1"
                        BackgroundColor="#F5F5F5"
                        Padding="14">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Assessments"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="Black" />

                            <ImageButton Grid.Column="1"
                                         Source="icon_add.png"
                                         BackgroundColor="Transparent"
                                         WidthRequest="28"
                                         HeightRequest="28"
                                         Aspect="AspectFit"
                                         Clicked="OnAddAssessmentClicked" />
                        </Grid>

                        <CollectionView x:Name="AssessmentsCollectionView"
                                        SelectionMode="None">

                            <CollectionView.EmptyView>
                                <Label Text="No assessments yet."
                                       FontSize="16"
                                       TextColor="Black" />
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12"
                                          Padding="0,8">

                                        <VerticalStackLayout Grid.Column="0"
                                            Spacing="2">
                                            <Grid Grid.Column="0"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="6">

                                                <Label Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="Black"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   VerticalTextAlignment="Center" />

                                                <Image Grid.Column="1"
                                                   Source="{Binding BellIconSource}"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   VerticalOptions="Center"
                                                   Aspect="AspectFit" />
                                            </Grid>

                                            <Label Text="{Binding Type}"
                                               FontSize="15"
                                               TextColor="Black" />

                                            <Label Text="{Binding EndDate, StringFormat='Due: {0:MM/dd/yyyy}'}"
                                               FontSize="15"
                                               TextColor="Black" />
                                        </VerticalStackLayout>

                                        <ImageButton Grid.Column="1"
                                                     Source="icon_edit.png"
                                                     BackgroundColor="Transparent"
                                                     WidthRequest="24"
                                                     HeightRequest="24"
                                                     Aspect="AspectFit"
                                                     CommandParameter="{Binding Id}"
                                                     Clicked="OnEditAssessmentClicked" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

                <Border Stroke="Black"
                        StrokeThickness="1"
                        BackgroundColor="#F5F5F5"
                        Padding="14">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Notes"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="Black" />

                            <ImageButton Grid.Column="1"
                                         Source="icon_share.png"
                                         BackgroundColor="Transparent"
                                         WidthRequest="28"
                                         HeightRequest="28"
                                         Aspect="AspectFit"
                                         Clicked="OnShareNotesClicked" />
                        </Grid>

                        <Label x:Name="NotesLabel"
                               FontSize="16"
                               TextColor="Black"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Delete Course"
                        ImageSource="icon_delete.png"
                        FontSize="16"
                        HeightRequest="58"
                        CornerRadius="16"
                        BackgroundColor="#F5F5F5"
                        TextColor="Black"
                        BorderColor="Black"
                        BorderWidth="2"
                        Margin="0,12,0,0"
                        Clicked="OnDeleteCourseClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>