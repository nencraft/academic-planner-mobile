<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AcademicPlanner.Models"
             x:Class="AcademicPlanner.Views.TermOverviewPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EFEFEF">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <Grid Grid.Row="0"
            Padding="16,12,16,8"
          ColumnDefinitions="56,*,56"
          ColumnSpacing="16"
          BackgroundColor="White">  

            <ImageButton Grid.Column="0"
                 Source="icon_back.png"
                 BackgroundColor="Transparent"
                 WidthRequest="48"
                 HeightRequest="48"
                 Padding="0"
                 Margin="0"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Aspect="AspectFit"
                 Clicked="OnBackClicked" />

            <Image Grid.Column="1"
           Source="wgu_owl.png"
           HeightRequest="56"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           Aspect="AspectFit" />

            <ImageButton Grid.Column="2"
                 Source="icon_add.png"
                 BackgroundColor="Transparent"
                 WidthRequest="48"
                 HeightRequest="48"
                 Padding="0"
                 Margin="0"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Aspect="AspectFit"
                 Clicked="OnAddCourseClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="#002f51"
                StrokeThickness="0"
                Padding="0,8">
            <VerticalStackLayout Spacing="2">
                <Label x:Name="TermTitleLabel"
                       Text="Term Overview"
                       TextColor="White"
                       FontSize="22"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="TermDatesLabel"
                       Text="StartDate - EndDate"
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="2"
      ColumnDefinitions="*,*"
      ColumnSpacing="40"
      Padding="0,14,0,10">

            <ImageButton Grid.Column="0"
                 Source="icon_delete.png"
                 BackgroundColor="Transparent"
                 WidthRequest="48"
                 HeightRequest="48"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Aspect="AspectFit"
                 Clicked="OnDeleteTermClicked" />

            <ImageButton Grid.Column="1"
                 Source="icon_edit.png"
                 BackgroundColor="Transparent"
                 WidthRequest="48"
                 HeightRequest="48"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Aspect="AspectFit"
                 Clicked="OnEditTermClicked" />
        </Grid>

        <CollectionView Grid.Row="3"
                        x:Name="CoursesCollectionView"
                        Margin="0,8,0,0"
                        SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24,32"
                                     Spacing="12">
                    <Label Text="No courses yet"
                           FontSize="24"
                           HorizontalOptions="Center" />
                    <Label Text="Tap the plus icon to add a course."
                           FontSize="16"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Course">
                    <Grid Padding="0,12">
                        <Border StrokeThickness="0"
                                BackgroundColor="#F5F5F5"
                                HorizontalOptions="Center"
                                WidthRequest="420"
                                Padding="16">

                            <Grid ColumnDefinitions="*,70">

                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="4"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="24"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="Black" />

                                    <Label Text="{Binding Status}"
                                           FontSize="16"
                                           HorizontalTextAlignment="Center"
                                           TextColor="Black" />
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="1"
                                    Source="icon_expand.png"
                                    BackgroundColor="Transparent"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    Aspect="AspectFit"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    CommandParameter="{Binding Id}"
                                    Clicked="OnCourseSelectedClicked" />

                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>