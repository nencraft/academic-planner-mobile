<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AcademicPlanner.Models"
             x:Class="AcademicPlanner.Views.TermsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EFEFEF">

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Padding="16,12,16,8"
      ColumnDefinitions="56,*,56"
      ColumnSpacing="16"
      BackgroundColor="White">

            <Image Grid.Column="1"
           Source="wgu_owl.png"
           HeightRequest="56"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           Aspect="AspectFit" />

            <ImageButton Grid.Column="2"
                 Source="icon_add.png"
                 BackgroundColor="Transparent"
                 WidthRequest="48"
                 HeightRequest="48"
                 Padding="0"
                 Margin="0"
                 HorizontalOptions="Center"
                 VerticalOptions="Center"
                 Aspect="AspectFit"
                 Clicked="OnAddTermClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="#002f51"
                StrokeThickness="0"
                Padding="0,10">
            <Label Text="WGU Academic Planner"
                   TextColor="White"
                   FontSize="22"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

        <CollectionView Grid.Row="2"
                        x:Name="TermsCollectionView"
                        Margin="0,24,0,0"
                        SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24,32"
                                     Spacing="12">
                    <Label Text="No terms yet"
                           FontSize="24"
                           HorizontalOptions="Center" />
                    <Label Text="Tap the plus icon to add your first term."
                           FontSize="16"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Term">
                    <Grid Padding="0,16">
                        <Border StrokeThickness="0"
                                BackgroundColor="#F5F5F5"
                                Shadow="{OnPlatform Android='0,4,10,0,#33000000'}"
                                HorizontalOptions="Center"
                                WidthRequest="480"
                                Padding="18">

                            <Grid ColumnDefinitions="*,70"
                                  VerticalOptions="Center">

                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="6"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="Black" />

                                    <Label FontSize="16"
                                           HorizontalTextAlignment="Center"
                                           TextColor="Black">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding StartDate, StringFormat='{0:MM/dd/yyyy}'}" />
                                                <Span Text=" - " />
                                                <Span Text="{Binding EndDate, StringFormat='{0:MM/dd/yyyy}'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <ImageButton Grid.Column="1"
                                     Source="icon_expand.png"
                                     BackgroundColor="Transparent"
                                     WidthRequest="56"
                                     HeightRequest="56"
                                     Aspect="AspectFit"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     CommandParameter="{Binding Id}"
                                     TranslationX="-15"
                                     Clicked="OnTermSelectedClicked" />

                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>